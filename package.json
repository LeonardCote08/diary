{
    "name": "diary",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "convert": "node scripts/svg-converter.js",
        "generate-tiles": "node scripts/generate-tiles.js",
        "clean-tiles": "powershell -Command \"Remove-Item -Path 'public/images/tiles/*' -Recurse -Force -ErrorAction SilentlyContinue\"",
        "regenerate-tiles": "npm run clean-tiles && npm run generate-tiles",
        "optimize-images": "npm run regenerate-tiles",
        "test-performance": "vite --host --open",
        "analyze": "vite build --mode analyze"
    },
    "dependencies": {
        "@solidjs/router": "^0.10.10",
        "howler": "^2.2.4",
        "openseadragon": "^5.0.1",
        "rbush": "^4.0.1",
        "solid-js": "^1.9.5"
    },
    "devDependencies": {
        "abs-svg-path": "^0.1.1",
        "cheerio": "^1.1.0",
        "commander": "^11.1.0",
        "parse-svg-path": "^0.1.2",
        "sharp": "^0.34.2",
        "vite": "^6.3.5",
        "vite-plugin-solid": "^2.11.6"
    }
}