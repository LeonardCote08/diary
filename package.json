{
    "name": "diary",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "convert": "node scripts/svg-converter.js",
        "tiles": "node scripts/generate-tiles-vips.js",
        "tiles:old": "node scripts/generate-tiles.js",
        "tiles:hq": "powershell -File regenerate-hq-tiles.ps1",
        "clean-tiles": "powershell -Command \"Remove-Item -Path 'public/images/tiles/*' -Recurse -Force -ErrorAction SilentlyContinue\"",
        "regenerate-tiles": "npm run clean-tiles && npm run tiles",
        "process-artwork": "npm run convert && npm run regenerate-tiles",
        "test": "npm run tiles:hq && npm run dev",
        "batch-tiles": "powershell -File scripts/batch-process-artworks.ps1"
    },
    "dependencies": {
        "@solidjs/router": "^0.10.10",
        "howler": "^2.2.4",
        "openseadragon": "^5.0.1",
        "rbush": "^4.0.1",
        "solid-js": "^1.9.5"
    },
    "devDependencies": {
        "abs-svg-path": "^0.1.1",
        "cheerio": "^1.1.0",
        "commander": "^11.1.0",
        "parse-svg-path": "^0.1.2",
        "vite": "^6.3.5",
        "vite-plugin-solid": "^2.11.6"
    }
}