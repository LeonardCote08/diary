{
    "name": "interactive-art-diary",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "start": "powershell -ExecutionPolicy Bypass -File scripts/start-app.ps1",
        "tiles": "powershell -ExecutionPolicy Bypass -File scripts/generate-hybrid-tiles-fixed.ps1",
        "tiles:jpeg": "powershell -ExecutionPolicy Bypass -File scripts/generate-hq-jpeg-tiles.ps1",
        "tiles:png": "powershell -ExecutionPolicy Bypass -File scripts/generate-png-tiles.ps1",
        "tiles:hybrid-old": "powershell -ExecutionPolicy Bypass -File scripts/generate-hybrid-tiles.ps1",
        "tiles:test": "powershell -ExecutionPolicy Bypass -File scripts/test-png-quality.ps1",
        "tiles:verify": "powershell -ExecutionPolicy Bypass -File scripts/verify-tiles.ps1",
        "tiles:batch": "powershell -ExecutionPolicy Bypass -File scripts/batch-process-artworks.ps1",
        "convert:svg": "node scripts/svg-converter.js",
        "cleanup": "powershell -ExecutionPolicy Bypass -File scripts/cleanup-project.ps1"
    },
    "dependencies": {
        "@solidjs/router": "^0.10.10",
        "howler": "^2.2.4",
        "openseadragon": "^5.0.1",
        "rbush": "^4.0.1",
        "solid-js": "^1.9.5"
    },
    "devDependencies": {
        "@types/openseadragon": "^3.0.10",
        "cheerio": "^1.0.0",
        "commander": "^11.1.0",
        "parse-svg-path": "^0.1.2",
        "abs-svg-path": "^0.1.1",
        "vite": "^5.4.11",
        "vite-plugin-solid": "^2.10.2"
    }
}